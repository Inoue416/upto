{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/codex_hook_guard.py\" --mode pre-tool",
            "timeout": 10,
            "statusMessage": "Checking command safety"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/codex_hook_guard.py\" --mode permission",
            "timeout": 10,
            "statusMessage": "Checking approval request"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/codex_hook_guard.py\" --mode user-prompt",
            "timeout": 10,
            "statusMessage": "Checking prompt for secrets"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/self_feedback.py\" --phase post-tool",
            "timeout": 60,
            "statusMessage": "Checking development-flow invariants"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/self_feedback.py\" --phase stop",
            "timeout": 240,
            "statusMessage": "Running project self-feedback checks"
          }
        ]
      }
    ]
  }
}
