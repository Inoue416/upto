{
  "name": "@upto/collector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit false",
    "dev": "COLLECTOR_DRY_RUN=true tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --root ../.. apps/collector/src",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@google/genai": "2.10.0",
    "@mozilla/readability": "0.6.0",
    "@upto/db": "workspace:*",
    "@upto/domain": "workspace:*",
    "fast-xml-parser": "5.9.3",
    "jsdom": "29.1.1",
    "p-limit": "7.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3"
  }
}
